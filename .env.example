# Ms. Smile English - Environment Variables
# Copy this file to .env and add your actual API keys
# DO NOT commit .env to GitHub!

# OpenAI API Key - Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# AI Provider (openai, gemini, qwen, demo)
AI_PROVIDER=openai

# Secret key for Flask sessions (generate a random string)
SECRET_KEY=your-secret-key-here

# Main admin account seeded on app startup
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
ADMIN_NAME=Ms Smile Admin

# Affiliate defaults
AFFILIATE_COMMISSION_RATE=20
AFFILIATE_COMMISSION_TYPE=percent
AFFILIATE_COMMISSION_FIXED_AMOUNT=0
ADMIN_AFFILIATE_CODE=ADMIN_DEFAULT

# Guest daily chat cap before login
GUEST_CHAT_LIMIT_PER_DAY=3

# Database URL (SQLite for local/dev)
DATABASE_URL=sqlite:///ms_smile.db

# Optional: Email SMTP settings for reminders
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# FROM_EMAIL=ms.smile.english@gmail.com
